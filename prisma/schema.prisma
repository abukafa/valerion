generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  name           String?
  email          String        @unique
  password       String?
  image          String?       // Google Profile Picture
  role           String        @default("USER") // Changed from Enum for SQLite
  reputation     Int           @default(0) // Seller Reputation Score
  isVerified     Boolean       @default(false) // Manual KYC Verification
  kycDocumentUrl String?       // Path to local storage for KTP
  kycRejectionReason String?   // Alasan penolakan KYC oleh admin
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  listings       Listing[]
  transactionsAsBuyer  Transaction[] @relation("BuyerTransactions")
  transactionsAsSeller Transaction[] @relation("SellerTransactions")
}

model Listing {
  id            String        @id @default(uuid())
  title         String
  description   String
  price         Float         // Changed from Decimal for SQLite
  originalPrice Float?        // Harga Normal (Before Sale)
  gameName      String
  images        String        // Stored as JSON string since SQLite lacks String[]
  isPremium     Boolean       @default(false)
  status        String        @default("AVAILABLE") // Changed from Enum
  sellerId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seller        User          @relation(fields: [sellerId], references: [id])
  transactions  Transaction[]
}

model Transaction {
  id            String        @id @default(uuid())
  listingId     String
  buyerId       String
  sellerId      String
  amount        Float         // Changed from Decimal for SQLite
  status        String        @default("PENDING") // Changed from Enum
  paymentUrl    String?       // Midtrans Payment URL
  paymentId     String?       // Midtrans Transaction ID
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  listing       Listing       @relation(fields: [listingId], references: [id])
  buyer         User          @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller        User          @relation("SellerTransactions", fields: [sellerId], references: [id])
}
